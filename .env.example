# Supabase — runtime (app, Vercel) : pooler transactionnel port 6543
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase — direct (migrations, import SQL, Prisma Studio)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js / NextAuth — obligatoire en production
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# URL publique de l'app
# Local : http://localhost:3000
# Production : https://myquickpos.app
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optionnel — proxy / hébergeurs (Vercel le détecte souvent automatiquement)
# AUTH_TRUST_HOST="true"

# SMTP — envoi des emails (création de compte, mot de passe oublié)
SMTP_HOST="mail.myquickpos.app"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="mbolo@myquickpos.app"
SMTP_PASSWORD="your-mailbox-password"
SMTP_FROM="MyQuickPOS <mbolo@myquickpos.app>"
SMTP_TIMEOUT_MS="10000"

# WasenderAPI — token Bearer de la session WhatsApp connectée
WASENDER_API_KEY="your_session_api_key"
WASENDER_TIMEOUT_MS="10000"

# Sécurité cron Vercel (rapports WhatsApp planifiés)
CRON_SECRET="generate-with-openssl-rand-base64-32"
